{
  "name": "onblast",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "api:dev": "npm run dev --workspace apps/api",
    "web:dev": "npm run dev --workspace apps/web",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "prisma": "^5.19.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20"
  }
}
